{
  "name": "saucedemo-automation",
  "version": "1.0.0",
  "description": "UI Automation tests for SauceDemo using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:login": "playwright test tests/login.spec.js",
    "test:inventory": "playwright test tests/inventory.spec.js",
    "test:checkout": "playwright test tests/checkout.spec.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1"
  }
}
